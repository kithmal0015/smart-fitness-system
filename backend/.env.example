PORT=5000
ADMIN_DASHBOARD_ORIGIN=http://localhost:3000
JWT_SECRET=change-this-secret
RESET_TOKEN_EXP_MINUTES=15
MONGODB_URI=mongodb://127.0.0.1:27017/smart-fitness-system

# Access request storage mode: mongo | sqlite
ACCESS_REQUEST_DB=mongo
# Used only when ACCESS_REQUEST_DB=sqlite
ACCESS_REQUEST_SQLITE_PATH=./data/access-requests.db
# true = backend starts even if MongoDB is unavailable (dev fallback mode)
ALLOW_START_WITHOUT_MONGO=false

# Option A: provide a bcrypt hash directly (recommended)
# ADMIN_PASSWORD_HASH=$2b$10$.................................................

# Option B: provide plain password and server will hash at startup
ADMIN_USERNAME=Kithmal0015
ADMIN_PASSWORD=12345

# Access request decision emails (approve/reject)
ACCESS_REVIEW_MAIL_ENABLED=true
# Send member confirmation mail after mobile register + payment success
REGISTER_PAYMENT_MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Smart Fitness <your-email@example.com>"
